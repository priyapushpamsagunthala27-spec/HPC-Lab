#include <stdio.h>
#include <omp.h>

#define ROWS 100
#define COLS 100

int main() {
    int i, j;
    int image[ROWS][COLS];
    int intensity_boost = 10;
    for(i = 0; i < ROWS; i++) {
        for(j = 0; j < COLS; j++) {
            image[i][j] = 100; 
        }
    }
    #pragma omp parallel for collapse(2) num_threads(4)
    for(i = 0; i < ROWS; i++) {
        for(j = 0; j < COLS; j++) {
            image[i][j] = image[i][j] + intensity_boost;
        }
    }
    printf("Processed Image Pixels (Partial):\n");
    for(i = 0; i < 5; i++) {
        for(j = 0; j < 5; j++) {
            printf("%d ", image[i][j]);
        }
        printf("\n");
    }

    return 0;
}
